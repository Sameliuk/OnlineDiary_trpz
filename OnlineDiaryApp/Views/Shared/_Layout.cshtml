@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - OnlineDiary</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-light">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">OnlineDiary</a>

            <div class="ml-auto">
                @if (Context.Session.GetString("Username") != null)
                {
                    <div class="dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="userDropdown" data-toggle="dropdown">
                            @Context.Session.GetString("Username")
                        </a>
                        <div class="dropdown-menu dropdown-menu-right">
                            <a class="dropdown-item" asp-controller="Note" asp-action="Index">Мої нотатки</a>
                            <a class="dropdown-item" asp-controller="User" asp-action="Logout">Вийти</a>
                        </div>
                    </div>
                }
                else
                {
                    <a class="btn btn-primary" asp-controller="User" asp-action="Login">Увійти</a>
                    <a class="btn btn-secondary" asp-controller="User" asp-action="Register">Реєстрація</a>
                }
            </div>
        </nav>
    </header>

    <div class="container">
        @RenderBody()
    </div>

    @RenderSection("Scripts", required: false)
</body>
</html>
