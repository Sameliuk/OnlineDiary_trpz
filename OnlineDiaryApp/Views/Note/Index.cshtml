@model IEnumerable<OnlineDiaryApp.Models.Note>

<h2>Мої нотатки</h2>

<a class="btn btn-primary mb-3" asp-action="Create">Створити нову нотатку</a>

<table class="table">
    <thead>
        <tr>
            <th>Заголовок</th>
            <th>Дата</th>
            <th>Теги</th>
            <th>Дії</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var note in Model)
        {
            <tr>
                <td>@note.Title</td>
                <td>@note.CreatedAt.ToString("g")</td>
                <td>
                    @foreach (var tag in note.Tags)
                    {
                        <span class="badge badge-info">@tag.Name</span>
                    }
                </td>
                <td>
                    <a class="btn btn-sm btn-warning" asp-action="Edit" asp-route-id="@note.Id">Редагувати</a>
                    <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@note.Id">Видалити</a>
                </td>
            </tr>
        }
    </tbody>
</table>
